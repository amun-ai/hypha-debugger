{
  "manifest_version": 3,
  "name": "Hypha Debugger — Browser Automation",
  "version": "0.5.0",
  "description": "Remote browser automation over Hypha RPC: AI agents can open/close/switch tabs, navigate, and inspect & control pages (DOM, screenshots, click/type by index, React). Works on any site, incl. strict-CSP.",
  "minimum_chrome_version": "116",
  "permissions": ["scripting", "offscreen", "sidePanel", "storage", "tabs", "activeTab", "alarms"],
  "optional_permissions": ["declarativeNetRequest"],
  "optional_host_permissions": ["<all_urls>"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_title": "Hypha Debugger (open side panel)" },
  "side_panel": { "default_path": "sidepanel.html" },
  "web_accessible_resources": [
    { "resources": ["main-world.js"], "matches": ["<all_urls>"] }
  ]
}
