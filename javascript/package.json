{
  "name": "hypha-debugger",
  "version": "0.1.1",
  "description": "Injectable debugger for web pages and AI agents, powered by Hypha RPC",
  "type": "module",
  "main": "dist/hypha-debugger.js",
  "module": "dist/hypha-debugger.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/hypha-debugger.mjs",
      "require": "./dist/hypha-debugger.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c && tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "debugger",
    "hypha",
    "rpc",
    "dom",
    "inspector",
    "ai-agent",
    "remote-debugging",
    "web-automation"
  ],
  "author": "Amun AI AB",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amun-ai/hypha-debugger.git"
  },
  "homepage": "https://github.com/amun-ai/hypha-debugger",
  "peerDependencies": {
    "hypha-rpc": ">=0.20.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.0.0",
    "typescript": "^5.5.0",
    "tslib": "^2.7.0",
    "vitest": "^2.0.0",
    "happy-dom": "^15.0.0"
  },
  "dependencies": {
    "html-to-image": "^1.11.0",
    "hypha-rpc": "^0.20.97"
  }
}
